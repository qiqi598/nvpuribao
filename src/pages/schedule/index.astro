---
import Base from '../../layouts/Base.astro';
import { readFileSync, existsSync } from 'fs';

function loadJSON(path: string, fallback: any = {}) {
  try { if (existsSync(path)) return JSON.parse(readFileSync(path, 'utf-8')); } catch {}
  return fallback;
}

const cache = loadJSON('data/schedule_cache.json');
const date = cache.date || '';
const shops = cache.shops || {};

const byRegion: Record<string, any[]> = {};
for (const [name, info] of Object.entries(shops as Record<string, any>)) {
  const region = info.district || '其他';
  if (!byRegion[region]) byRegion[region] = [];
  byRegion[region].push({ name, ...info });
}

// 按在岗人数排序
for (const region in byRegion) {
  byRegion[region].sort((a, b) => (b.working_count || 0) - (a.working_count || 0));
}

const totalShops = Object.keys(shops).length;
const totalMaids = Object.values(shops as Record<string, any>).reduce((s: number, v: any) => s + (v.working_count || 0), 0);
const today = new Date().toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric', weekday: 'long' });
const todayISO = new Date().toISOString().split('T')[0];

// 生成 ItemList 结构化数据（排班列表）
const scheduleListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": `${todayISO}杭州女仆店排班列表`,
  "description": `${today}杭州${totalShops}家女仆店实时排班，${totalMaids}位女仆在岗`,
  "numberOfItems": totalShops,
  "itemListElement": Object.values(shops).slice(0, 50).map((shop: any, idx) => ({
    "@type": "ListItem",
    "position": idx + 1,
    "item": {
      "@type": "LocalBusiness",
      "name": shop.name || "女仆店",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "杭州",
        "addressRegion": shop.district || "浙江省"
      },
      "url": shop.msg_link || (shop.username ? `https://t.me/${shop.username}` : undefined)
    }
  }))
};
---
<Base
  title={`今日排班 - ${totalShops}家杭州女仆店营业中，${totalMaids}人在岗 - 女仆日报`}
  description={`${today}杭州女仆馆今日排班汇总。${totalShops}家营业，在岗约${totalMaids}人。覆盖上城、拱墅、西湖、滨江、余杭、钱塘、萧山、临平全区域。每日12:00/13:00/14:00/15:00四次更新。`}
  keywords="杭州女仆排班,女仆店今日排班,女仆馆在岗人数,杭州女仆营业,女仆店实时排班"
  schemaType="ItemList"
  schemaData={scheduleListSchema}
>
  <h1 style="font-size:1.5rem;color:#1a1a2e;margin-bottom:8px">
    📅 今日排班速报 · {date}
  </h1>
  <div style="background:#e8f5e9;padding:12px;border-radius:6px;margin-bottom:16px;border-left:4px solid #4caf50">
    <p style="font-size:0.95rem;color:#2e7d32;line-height:1.6">
      📊 <strong>{today}</strong><br>
      🏪 共 <strong>{totalShops}</strong> 家营业<br>
      👯 在岗约 <strong>{totalMaids}</strong> 人<br>
      ⏰ 更新时间：每日12:00 / 13:00 / 14:00 / 15:00
    </p>
  </div>

  {Object.keys(byRegion).length === 0 && (
    <div class="card"><p style="color:#999">今日排班数据更新中，请稍后查看...</p></div>
  )}

  {Object.entries(byRegion).map(([region, shopList]) => (
    <div class="card" id={`region-${region}`}>
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:12px">
        <h2 style="margin:0">📍 {region}（{shopList.length}家营业）</h2>
        <span style="color:#666;font-size:0.85rem">
          {shopList.reduce((sum, s) => sum + (s.working_count || 0), 0)}人在岗
        </span>
      </div>
      <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:8px;margin-top:12px">
        {shopList.map((shop: any) => (
          <a href={shop.msg_link || `https://t.me/${shop.username}`} target="_blank" style="text-decoration:none" title={`${shop.name} - ${shop.working_count}人在岗`}>
            <div style="background:#f8f9fa;border-radius:6px;padding:8px;font-size:0.85rem;text-align:center;transition:all 0.15s" onmouseover="this.style.background='#e8f4fd';this.style.transform='translateY(-2px)'" onmouseout="this.style.background='#f8f9fa';this.style.transform='translateY(0)'">
              <div style="color:#1a1a2e;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">{shop.name}</div>
              <div style="color:#43a047;margin-top:2px;font-weight:600">{shop.working_count}人在岗</div>
              {shop.resting_count > 0 && <div style="color:#bbb;font-size:0.75rem">休{shop.resting_count}人</div>}
            </div>
          </a>
        ))}
      </div>
    </div>
  ))}

  <!-- SEO内容：排班说明 -->
  <div class="card" style="background:#f9f9f9;margin-top:16px">
    <h2 style="font-size:1.05rem;color:#333;margin-bottom:10px">💡 如何使用排班速报？</h2>
    <ul style="line-height:1.8;color:#555;font-size:0.9rem;padding-left:20px">
      <li><strong>实时更新</strong>：每日12:00/13:00/14:00/15:00四次抓取各店铺TG频道排班信息</li>
      <li><strong>快速查找</strong>：按区域分类，点击店铺卡片可直接跳转TG排班频道</li>
      <li><strong>人数排序</strong>：每个区域内按在岗人数降序排列，方便选择大店</li>
      <li><strong>数据来源</strong>：所有数据来自店铺TG公开频道，确保准确性</li>
      <li><strong>搜索功能</strong>：使用 @nvpuhuangyebot 机器人可快速查询指定店铺排班</li>
    </ul>
  </div>

  <!-- 数据说明 -->
  <div class="card" style="background:#fff3e0;border-left:3px solid #fb8c00">
    <p style="font-size:0.85rem;color:#555">
      📌 <strong>数据说明</strong><br>
      • 点击店铺名可直接跳转TG排班频道查看完整排班<br>
      • "在岗"指当前时段已发布排班的女仆人数<br>
      • "休"指已公布休息状态的女仆人数<br>
      • 部分店铺可能不定期更新排班，实际以店铺频道为准
    </p>
  </div>
</Base>
