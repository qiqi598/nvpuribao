---
import Base from '../../layouts/Base.astro';
import { readFileSync, existsSync } from 'fs';

let shops: any[] = [];
try {
  const csv = readFileSync('data/shops.csv', 'utf-8').replace(/^\uFEFF/, '');
  const lines = csv.split('\n').filter(l => l.trim());
  const headers = lines[0].split(',').map(h => h.trim());
  for (let i = 1; i < lines.length; i++) {
    const vals = lines[i].split(',').map(v => v.trim());
    const obj: any = {};
    headers.forEach((h, idx) => { obj[h] = vals[idx] || ''; });
    shops.push(obj);
  }
} catch {}

// 按区域分组
const byRegion: Record<string, any[]> = {};
for (const s of shops) {
  const region = s.district || s.area || s.region || '其他';
  if (!byRegion[region]) byRegion[region] = [];
  byRegion[region].push(s);
}

const regions = Object.keys(byRegion);
const total = shops.length;
---
<Base
  title="杭州女仆馆店铺导航大全 - 女仆日报"
  description={`杭州${total}家女仆馆完整导航，覆盖上城、拱墅、西湖、滨江、余杭、钱塘、萧山全区域。含TG联系方式和排班查询。`}
>
  <h2>🗺️ 杭州女仆馆导航 · {total}家</h2>
  <p class="meta" style="margin-bottom:20px">覆盖杭州全区域 · 含TG直达链接</p>

  <!-- 区域快跳 -->
  <div class="card" style="margin-bottom:20px">
    {regions.map(r => (
      <a href={`#${r}`} class="tag" style="margin:4px;display:inline-block">{r}（{byRegion[r].length}家）</a>
    ))}
  </div>

  {regions.length === 0 && (
    <div class="card">
      <p style="color:#999">店铺数据加载中...</p>
    </div>
  )}

  {regions.map(region => (
    <div class="card" id={region}>
      <h2>📍 {region}（{byRegion[region].length}家）</h2>
      <div class="grid" style="margin-top:12px">
        {byRegion[region].map((shop: any) => (
          <div style="background:#f8f9fa;border-radius:6px;padding:12px">
            <strong style="color:#1a1a2e;font-size:0.95rem">{shop.shop || shop.name}</strong>
            {shop.username && (
              <div>
                <a href={`https://t.me/${shop.username}`} target="_blank" style="color:#1565c0;font-size:0.8rem;margin-top:4px;text-decoration:none">@{shop.username}</a>
              </div>
            )}
          </div>
        ))}
      </div>
    </div>
  ))}
</Base>
