---
import Base from '../layouts/Base.astro';
import { readFileSync, existsSync } from 'fs';

// 读取今日数据
function loadJSON(path: string, fallback: any = {}) {
  try {
    if (existsSync(path)) return JSON.parse(readFileSync(path, 'utf-8'));
  } catch {}
  return fallback;
}

const gossip = existsSync('data/gossip_report_gossip_s1.txt') 
  ? readFileSync('data/gossip_report_gossip_s1.txt', 'utf-8').slice(0, 500) + '...'
  : '今日八卦内容加载中...';

const schedule = loadJSON('data/schedule_cache.json');
const today = new Date().toLocaleDateString('zh-CN', { month: 'long', day: 'numeric', weekday: 'long' });
---
<Base 
  title="杭州女仆馆今日排班 八卦快报 - 女仆日报"
  description="汇聚杭州女仆圈最新资讯：今日排班、八卦快报、店铺测评、新店预警。覆盖上城、拱墅、西湖、滨江、余杭等全区域。"
>
  <div style="margin-bottom:20px">
    <h2 style="font-size:1.5rem;color:#1a1a2e">📰 {today} · 杭州女仆圈资讯</h2>
    <p style="color:#666;margin-top:6px">实时聚合排班、八卦、测评 · 每日自动更新</p>
  </div>

  <!-- 快捷入口 -->
  <div class="grid" style="margin-bottom:24px">
    <a href="/gossip" class="card" style="text-decoration:none;color:inherit;border-left:4px solid #e53935">
      <div style="font-size:1.5rem">🔥</div>
      <h3 style="margin-top:8px">今日八卦</h3>
      <p style="color:#666;font-size:0.9rem">圈内最新爆料与动态</p>
    </a>
    <a href="/schedule" class="card" style="text-decoration:none;color:inherit;border-left:4px solid #1e88e5">
      <div style="font-size:1.5rem">📅</div>
      <h3 style="margin-top:8px">今日排班</h3>
      <p style="color:#666;font-size:0.9rem">全区域在岗女仆速查</p>
    </a>
    <a href="/shops" class="card" style="text-decoration:none;color:inherit;border-left:4px solid #43a047">
      <div style="font-size:1.5rem">🗺️</div>
      <h3 style="margin-top:8px">店铺导航</h3>
      <p style="color:#666;font-size:0.9rem">杭州139家店铺一览</p>
    </a>
    <a href="/reviews" class="card" style="text-decoration:none;color:inherit;border-left:4px solid #fb8c00">
      <div style="font-size:1.5rem">⭐</div>
      <h3 style="margin-top:8px">测评速报</h3>
      <p style="color:#666;font-size:0.9rem">真实测评汇总</p>
    </a>
  </div>

  <!-- 八卦预览 -->
  <div class="card">
    <h2>🔥 今日八卦快报</h2>
    <div style="white-space:pre-wrap;line-height:1.8;font-size:0.95rem">{gossip}</div>
    <a href="/gossip" class="btn" style="margin-top:16px;display:inline-block">查看完整版 →</a>
  </div>

  <!-- SEO 关键词区 -->
  <div class="card" style="background:#f9f9f9">
    <h2 style="font-size:1rem;color:#666">覆盖区域</h2>
    <div style="margin-top:10px">
      {['上城区', '拱墅区', '西湖区', '滨江区', '余杭区', '钱塘区', '萧山区', '江干区'].map(d => (
        <a href={`/shops/${d}`} class="tag" style="margin-bottom:8px;display:inline-block">{d}</a>
      ))}
    </div>
  </div>
</Base>
