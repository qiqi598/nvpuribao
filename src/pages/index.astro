---
import Base from '../layouts/Base.astro';
import { readFileSync, existsSync } from 'fs';

function loadJSON(path: string, fallback: any = {}) {
  try { if (existsSync(path)) return JSON.parse(readFileSync(path, 'utf-8')); } catch {}
  return fallback;
}

// 八卦预览
let gossipText = '';
for (const f of ['data/gossip_report_gossip_s3_prev.txt','data/gossip_report_gossip_s2.txt','data/gossip_report_gossip_s1.txt']) {
  if (existsSync(f)) { gossipText = readFileSync(f, 'utf-8'); break; }
}
const gossipPreview = gossipText.slice(0, 600) + (gossipText.length > 600 ? '...' : '');

// 排班数据
const cache = loadJSON('data/schedule_cache.json');
const shops = cache.shops || {};
const byRegion: Record<string, any[]> = {};
for (const [name, info] of Object.entries(shops as Record<string, any>)) {
  const region = (info as any).district || '其他';
  if (!byRegion[region]) byRegion[region] = [];
  byRegion[region].push({ name, ...(info as any) });
}
const totalShops = Object.keys(shops).length;
const totalMaids = Object.values(shops as Record<string, any>).reduce((s: number, v: any) => s + (v.working_count || 0), 0);
const date = cache.date || '';
const today = new Date().toLocaleDateString('zh-CN', { month: 'long', day: 'numeric', weekday: 'long' });

// 读取shops.csv获取总店铺数
let totalShopsInDatabase = 142; // 默认值
try {
  const shopsCSV = readFileSync('data/shops.csv', 'utf-8');
  totalShopsInDatabase = shopsCSV.split('\n').filter(l => l.trim()).length - 1; // 减去表头,过滤空行
} catch {}

// 结构化数据（首页用WebSite schema）
const schemaData = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "女仆日报",
  "alternateName": "杭州女仆黄页",
  "url": "https://nvpuribao.com",
  "description": `杭州女仆圈官方黄页导航，收录${totalShopsInDatabase}家女仆店铺。提供每日排班更新、真实测评、八卦快报、抽奖福利。覆盖杭州女仆馆、女仆咖啡厅、女仆桌游吧全业态。`,
  "potentialAction": {
    "@type": "SearchAction",
    "target": {
      "@type": "EntryPoint",
      "urlTemplate": "https://t.me/nvpuhuangyebot?start={search_term_string}"
    },
    "query-input": "required name=search_term_string"
  },
  "publisher": {
    "@type": "Organization",
    "name": "女仆日报",
    "url": "https://nvpuribao.com",
    "logo": {
      "@type": "ImageObject",
      "url": "https://nvpuribao.com/logo.png"
    }
  }
};
---
<Base
  title={`杭州女仆黄页 - ${totalShopsInDatabase}家店铺实时排班|测评|八卦 - 女仆日报`}
  description={`杭州女仆圈官方黄页导航，收录上城/拱墅/西湖/滨江/余杭/钱塘/萧山/临平全区域${totalShopsInDatabase}家女仆店铺。提供每日排班更新、真实测评、八卦爆料、抽奖福利。覆盖杭州女仆馆、女仆咖啡厅、女仆桌游吧、女仆私影等全业态。`}
  keywords="杭州女仆,杭州女仆馆,杭州女仆黄页,女仆店,杭州女仆排班,女仆测评,女仆咖啡厅,上城女仆,拱墅女仆,西湖女仆,滨江女仆,余杭女仆"
  schemaType="WebSite"
  schemaData={schemaData}
>
  <!-- SEO优化：添加H1标题 -->
  <h1 style="font-size:1.6rem;color:#1a1a2e;margin-bottom:8px;line-height:1.4">
    杭州女仆黄页 - {totalShopsInDatabase}家店铺实时排班与测评
  </h1>
  <p style="color:#666;margin-bottom:20px;font-size:0.95rem">
    覆盖<strong>上城、拱墅、西湖、滨江、余杭、钱塘、萧山、临平</strong>全区域 · 每日自动更新
  </p>

  <div style="margin-bottom:20px;padding:12px;background:#f0f7ff;border-left:4px solid #1e88e5;border-radius:4px">
    <p style="font-size:0.9rem;color:#333">
      📅 <strong>{today}</strong> · 今日<strong>{totalShops}</strong>家营业，<strong>{totalMaids}</strong>位女仆在岗
    </p>
  </div>

  <!-- 快捷入口 5个 -->
  <div class="quick-nav" style="display:grid;grid-template-columns:repeat(5,1fr);gap:10px;margin-bottom:20px">
    {[
      {href:'/gossip', emoji:'🔥', label:'今日八卦', color:'#e53935'},
      {href:'/schedule', emoji:'📅', label:'今日排班', color:'#1e88e5'},
      {href:'/shops', emoji:'🗺️', label:'店铺导航', color:'#43a047'},
      {href:'/reviews', emoji:'⭐', label:'测评速报', color:'#fb8c00'},
      {href:'/lottery', emoji:'🎁', label:'抽奖福利', color:'#8e24aa'},
    ].map(item => (
      <a href={item.href} class="card" style={`text-decoration:none;color:inherit;border-left:4px solid ${item.color};padding:14px 12px`} title={`查看杭州女仆${item.label}`}>
        <div style="font-size:1.4rem">{item.emoji}</div>
        <div style="font-weight:600;margin-top:6px;font-size:0.9rem">{item.label}</div>
      </a>
    ))}
  </div>

  <!-- 今日排班概览 -->
  <div class="card" style="margin-bottom:16px">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:14px">
      <h2 style="margin:0">📅 今日排班 · {date}</h2>
      <a href="/schedule" style="color:#1565c0;font-size:0.85rem;text-decoration:none" title="查看完整排班">查看全部 →</a>
    </div>
    <p style="color:#666;font-size:0.85rem;margin-bottom:12px">共 <strong>{totalShops}</strong> 家营业 · 在岗约 <strong>{totalMaids}</strong> 人</p>
    {Object.entries(byRegion).slice(0, 3).map(([region, shopList]) => (
      <div style="margin-bottom:14px">
        <div style="font-size:0.85rem;color:#666;margin-bottom:6px;font-weight:600">📍 {region}（{shopList.length}家）</div>
        <div class="shop-grid" style="display:grid;grid-template-columns:repeat(4,1fr);gap:6px">
          {shopList.slice(0, 8).map((shop: any) => (
            <a href={shop.msg_link || `https://t.me/${shop.username}`} target="_blank" style="text-decoration:none" title={`${shop.name}女仆店 - ${shop.working_count}人在岗`}>
              <div style="background:#f8f9fa;border-radius:5px;padding:6px 8px;font-size:0.8rem;text-align:center">
                <div style="color:#1a1a2e;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">{shop.name}</div>
                <div style="color:#43a047;font-size:0.75rem">{shop.working_count}人</div>
              </div>
            </a>
          ))}
        </div>
      </div>
    ))}
    <div style="text-align:center;margin-top:12px">
      <a href="/schedule" class="btn" style="font-size:0.85rem">查看完整排班（{totalShops}家）→</a>
    </div>
  </div>

  <!-- 八卦预览 -->
  <div class="card" style="margin-bottom:16px">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:12px">
      <h2 style="margin:0">🔥 今日八卦快报</h2>
      <a href="/gossip" style="color:#1565c0;font-size:0.85rem;text-decoration:none" title="查看完整八卦">查看完整版 →</a>
    </div>
    <div style="white-space:pre-wrap;line-height:1.8;font-size:0.9rem;color:#333">{gossipPreview || '今日八卦内容更新中...'}</div>
  </div>

  <!-- 频道/群/机器人宣传 -->
  <div class="card" style="background:linear-gradient(135deg,#1a1a2e,#16213e);color:white;margin-bottom:16px">
    <h2 style="color:white;margin-bottom:14px">📢 关注我们的TG频道</h2>
    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:10px">
      <a href="https://t.me/nvputoutiaoribao" target="_blank" style="text-decoration:none" title="女仆头条日报TG频道">
        <div style="background:rgba(255,255,255,0.1);border-radius:8px;padding:12px;text-align:center">
          <div style="font-size:1.5rem">📡</div>
          <div style="color:white;font-weight:600;margin-top:6px;font-size:0.9rem">女仆头条日报</div>
          <div style="color:#aaa;font-size:0.75rem;margin-top:4px">@nvputoutiaoribao</div>
          <div style="color:#7ec8e3;font-size:0.75rem;margin-top:2px">每日八卦+排班+抽奖</div>
        </div>
      </a>
      <a href="https://t.me/nvpuhuangyebot" target="_blank" style="text-decoration:none" title="女仆黄页搜索机器人">
        <div style="background:rgba(255,255,255,0.1);border-radius:8px;padding:12px;text-align:center">
          <div style="font-size:1.5rem">🤖</div>
          <div style="color:white;font-weight:600;margin-top:6px;font-size:0.9rem">女仆黄页机器人</div>
          <div style="color:#aaa;font-size:0.75rem;margin-top:4px">@nvpuhuangyebot</div>
          <div style="color:#7ec8e3;font-size:0.75rem;margin-top:2px">店铺搜索·排班查询</div>
        </div>
      </a>
      <a href="https://t.me/ttrbqun" target="_blank" style="text-decoration:none" title="女仆圈讨论交流群">
        <div style="background:rgba(255,255,255,0.1);border-radius:8px;padding:12px;text-align:center">
          <div style="font-size:1.5rem">💬</div>
          <div style="color:white;font-weight:600;margin-top:6px;font-size:0.9rem">讨论交流群</div>
          <div style="color:#aaa;font-size:0.75rem;margin-top:4px">@ttrbqun</div>
          <div style="color:#7ec8e3;font-size:0.75rem;margin-top:2px">行业资讯·经验分享</div>
        </div>
      </a>
    </div>
  </div>

  <!-- SEO区域导航 + 关键词密度优化 -->
  <div class="card" style="background:#f9f9f9">
    <h2 style="font-size:1.1rem;color:#333;margin-bottom:10px">📍 杭州女仆店铺覆盖区域</h2>
    <p style="font-size:0.85rem;color:#666;margin-bottom:12px;line-height:1.6">
      女仆日报收录杭州全区域女仆馆、女仆咖啡厅、女仆桌游吧、女仆私影等{totalShopsInDatabase}家店铺，
      包括<strong>上城区女仆店</strong>、<strong>拱墅区女仆馆</strong>、<strong>西湖区女仆咖啡厅</strong>、
      <strong>滨江区女仆店</strong>、<strong>余杭区女仆馆</strong>、<strong>钱塘区女仆店</strong>、
      <strong>萧山区女仆咖啡厅</strong>、<strong>临平区女仆馆</strong>全业态。
    </p>
    <div style="margin-top:10px">
      {['上城区','拱墅区','西湖区','滨江区','余杭区','钱塘区','萧山区','临平区'].map(d => (
        <a href={`/shops#${d}`} class="tag" style="margin:3px;display:inline-block" title={`${d}女仆店铺导航`}>{d}</a>
      ))}
    </div>
  </div>

  <!-- SEO内容：服务说明 -->
  <div class="card" style="background:white;margin-bottom:16px">
    <h2 style="font-size:1.05rem;color:#333;margin-bottom:10px">💡 女仆日报提供什么服务？</h2>
    <ul style="line-height:1.8;color:#555;font-size:0.9rem;padding-left:20px">
      <li><strong>实时排班更新</strong>：每日12:00/13:00/14:00/15:00四次更新，{totalShops}家店铺在岗信息一目了然</li>
      <li><strong>八卦快报</strong>：汇总7大TG群聊天记录，AI筛选提炼有价值行业动态、爆料、避雷</li>
      <li><strong>真实测评</strong>：收集测评群用户反馈，筛选优质店铺，帮你避坑</li>
      <li><strong>抽奖福利</strong>：每日0:00/12:00两次抽奖，免费金币、优惠券等福利</li>
      <li><strong>店铺搜索</strong>：@nvpuhuangyebot 机器人，输入店铺名/区域快速查找</li>
    </ul>
  </div>
</Base>

<style>
  /* 移动端优化 */
  @media (max-width: 768px) {
    .quick-nav { grid-template-columns: repeat(3, 1fr) !important; gap: 8px !important; }
    .shop-grid { grid-template-columns: repeat(2, 1fr) !important; gap: 4px !important; }
  }
  
  @media (max-width: 480px) {
    .quick-nav { grid-template-columns: repeat(2, 1fr) !important; }
  }
</style>
